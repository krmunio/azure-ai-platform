# 중앙(별도 구독) 관리 Private DNS Zone을 참조해 zone group을 직접 만들 경우에만 설정.
# 기본(미설정)은 중앙 Azure Policy가 A 레코드를 등록한다고 가정.
# central_private_dns_zone_id = "/subscriptions/<central-sub-id>/resourceGroups/<rg>/providers/Microsoft.Network/privateDnsZones/privatelink.azurecr.io"
