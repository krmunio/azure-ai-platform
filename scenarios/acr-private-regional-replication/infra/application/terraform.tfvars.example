location    = "koreacentral"
name_prefix = "acrpriv"

# subscription_id = "<workload-subscription-id>"

# resource_group_name = "my-acr-rg"
# vnet_address_space  = ["10.50.0.0/16"]
# pe_subnet_prefix    = ["10.50.1.0/24"]
# acr_sku             = "Premium"

# 중앙(별도 구독) 관리 Private DNS Zone을 data로 조회해 zone group을 직접 만들 경우에만 설정.
# 기본은 중앙 Azure Policy가 A 레코드를 등록한다고 가정(zone group 미생성).
# use_central_dns_zone_group      = true
# central_dns_subscription_id     = "<central-connectivity-subscription-id>"
# central_dns_resource_group_name = "central-dns-rg"
# central_private_dns_zone_name   = "privatelink.azurecr.io"
